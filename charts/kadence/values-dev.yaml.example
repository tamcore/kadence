# Example dev-environment overrides. Copy to `values-dev.yaml` (gitignored)
# and fill in your own infra values. Do NOT commit `values-dev.yaml`.

image:
  tag: "" # e.g. pin to a specific released tag

ingress:
  enabled: true
  className: nginx
  host: kadence.example.com
  tls: true

# Non-secret config overrides.
config:
  KADENCE_ENV: production
  KADENCE_LLM_BASE_URL: "https://your-openai-compatible-endpoint.example.com/v1"
  KADENCE_LLM_MODEL: "your-llm-model"
  KADENCE_EMBED_BASE_URL: "https://your-openai-compatible-endpoint.example.com/v1"
  # Changing the embedding model re-embeds existing RAG chunks automatically.
  # ROLLOUT RULE: don't change it in the same deploy that first ships the
  # re-index feature — change it in a later deploy (see values.yaml comment).
  KADENCE_EMBED_MODEL: "your-embedding-model"
  KADENCE_ADMIN_USERNAME: "admin"
  KADENCE_ADMIN_EMAIL: "admin@example.com"
  # KADENCE_TRUSTED_ORIGINS: "https://kadence.example.com"
  # KADENCE_WEBAUTHN_RP_ID: "kadence.example.com"
  #   Uncomment both (and secrets.KADENCE_ENCRYPTION_KEY below) to enable passkeys.
  #   Without all three, passkey login/registration silently stays unavailable.

# Secret overrides. Replace CHANGEME with real secret values before deploying.
secrets:
  KADENCE_CSRF_SECRET: "CHANGEME"
  KADENCE_LLM_API_KEY: "CHANGEME"
  KADENCE_EMBED_API_KEY: "CHANGEME"
  KADENCE_ADMIN_PASSWORD: "CHANGEME"
  # KADENCE_ENCRYPTION_KEY: "CHANGEME" # base64-encoded 32-byte key; generate with:
  #   openssl rand -base64 32
  #   Required for passkeys (with config.KADENCE_WEBAUTHN_RP_ID +
  #   config.KADENCE_TRUSTED_ORIGINS above) and for user-defined MCP servers
  #   (with config.KADENCE_USER_MCP_ALLOWED_HOSTS). Without it, both features
  #   silently stay unavailable.

# Bundled Postgres (pgvector). Set storageClass to your cluster's default
# (or a specific pgvector-capable SSD class) if the empty default isn't suitable.
postgres:
  enabled: true
  storageClass: "" # e.g. a cluster-specific storage class; "" uses the cluster default
  password: "CHANGEME"

externalDatabase:
  url: "" # postgres://user:pass@host:5432/db?sslmode=require

# Example MCP server (commented out). Uncomment and adjust to add a remote
# MCP tool server, reachable by the app via MCP_<NAME>_<SCOPE>_* env vars.
# mcp:
#   servers:
#     - name: garmin
#       scope: global
#       image: example/garmin-mcp:latest
#       transport: streamable-http
#       port: 8000
#       path: /mcp
#       env:
#         - name: GARMIN_MCP_TRANSPORT
#           value: streamable-http
#         # The pod now runs as the fixed non-root uid 65532 (mcp.podSecurityContext),
#         # so $HOME can no longer be /root; point it at the writable, fsGroup-owned
#         # persistent volume instead. garmin-mcp writes its session cache to
#         # $HOME/.garminconnect, so this must line up with persistence.mountPath below.
#         - name: HOME
#           value: /data
#       existingSecret: garmin-creds
#       persistence:
#         enabled: true
#         size: 1Gi
#         # Upgrading an existing deployment: the PVC content is unchanged and
#         # appears at the new path, but pre-existing root-owned token files are
#         # only readable by uid 65532 if the storage class honors fsGroup
#         # (fsGroupPolicy: File). If tokens turn unreadable, re-login via the
#         # garmin_login tool once.
#         mountPath: /data/.garminconnect
#       # tools: ["get_activity*", "*_workout", "*_workouts", "get_exercise_types", "get_workout*"]
#       #   app-side allowlist of glob patterns (matched against the unprefixed tool
#       #   name); unset = all tools. Lets you shorten the LLM tool list without the
#       #   MCP server's own filtering.

# Example markitdown-mcp ingestion sidecar (commented out). Uncomment to
# convert uploaded documents (PDF, images, office docs) via markitdown-mcp
# instead of the built-in PDF-only extractor. Public image; no infra required.
# markitdown:
#   enabled: true
#   image: mcp/markitdown:latest
#   basicAuth:
#     # Recommended under `helm template | kubectl apply` (this dev deploy path):
#     # a fixed password keeps the app and markitdown sidecar in sync across
#     # redeploys instead of regenerating (and briefly 401'ing) each time.
#     password: "CHANGEME"
